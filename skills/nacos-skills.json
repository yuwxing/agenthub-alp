      "outputs": {
        "type": "object",
        "properties": {
          "forecast": { "type": "array" },
          "confidenceInterval": { "type": "object" },
          "trendDirection": { "type": "string" }
        }
      }
    },
    {
      "name": "classifier",
      "version": "v1",
      "description": "对数据进行分类和分组",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "items": { "type": "array" },
          "categories": { "type": "array" },
          "classificationField": { "type": "string" }
        },
        "required": ["items"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "classified": { "type": "object" },
          "distribution": { "type": "object" }
        }
      }
    },
    {
      "name": "decision-maker",
      "version": "v1",
      "description": "基于评估矩阵选择最优方案",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "options": { "type": "array" },
          "criteria": { "type": "array" },
          "weights": { "type": "object" }
        },
        "required": ["options", "criteria"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "chosen": { "type": "object" },
          "scores": { "type": "object" },
          "rationale": { "type": "string" }
        }
      }
    },
    {
      "name": "resource-allocator",
      "version": "v1",
      "description": "优化分配计算资源、任务队列和能力配额",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "tasks": { "type": "array" },
          "resources": { "type": "object" },
          "constraints": { "type": "object" }
        },
        "required": ["tasks", "resources"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "allocation": { "type": "object" },
          "utilization": { "type": "number" },
          "bottlenecks": { "type": "array" }
        }
      }
    },
    {
      "name": "optimizer",
      "version": "v1",
      "description": "在约束条件下寻找最优解",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "objective": { "type": "string" },
          "variables": { "type": "array" },
          "constraints": { "type": "array" }
        },
        "required": ["objective", "variables"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "optimalSolution": { "type": "object" },
          "objectiveValue": { "type": "number" }
        }
      }
    },
    {
      "name": "input-parser",
      "version": "v1",
      "description": "解析用户输入，提取结构化信息",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "input": { "type": "string" },
          "format": { "type": "string", "enum": ["text", "json", "csv", "natural"] }
