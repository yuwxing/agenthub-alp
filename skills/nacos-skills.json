        "required": ["input"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "parsed": { "type": "object" },
          "confidence": { "type": "number" }
        }
      }
    },
    {
      "name": "output-formatter",
      "version": "v1",
      "description": "将 Agent 执行结果格式化为标准化输出",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "data": { "type": "object" },
          "targetFormat": { "type": "string", "enum": ["json", "markdown", "html", "text"] },
          "template": { "type": "string" }
        },
        "required": ["data"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "formatted": { "type": "string" },
          "format": { "type": "string" }
        }
      }
    },
    {
      "name": "error-handler",
      "version": "v1",
      "description": "捕获异常并执行恢复策略",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "error": { "type": "object" },
          "context": { "type": "object" },
          "retryCount": { "type": "integer", "default": 3 }
        },
        "required": ["error"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "resolved": { "type": "boolean" },
          "action": { "type": "string" },
          "fallbackResult": { "type": "object" }
        }
      }
    },
    {
      "name": "negotiator",
      "version": "v1",
      "description": "在多个 Agent 之间协调达成共识",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "participants": { "type": "array" },
          "proposals": { "type": "array" },
          "constraints": { "type": "object" }
        },
        "required": ["participants"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "consensus": { "type": "object" },
          "agreedBy": { "type": "array" },
          "disagreements": { "type": "array" }
        }
      }
    },
    {
      "name": "whatif-analyzer",
      "version": "v1",
      "description": "模拟不同场景下的可能结果",
      "source": "nacos",
      "parameters": {
        "type": "object",
        "properties": {
          "scenario": { "type": "object" },
          "variables": { "type": "array" },
          "assumptions": { "type": "array" }
